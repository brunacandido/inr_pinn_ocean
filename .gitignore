# ── Data (too heavy) ──────────────────────────────────────────────────────────
data/raw/
data/processed/
data/splits/
notebooks/data/          # zarr stores (can be several GB each)

# Catch any zarr / netCDF / numpy binary that ends up elsewhere
*.zarr
*.nc
*.npz
*.npy

# ── Model outputs (too heavy) ─────────────────────────────────────────────────
# Trained checkpoints — share via release assets or cloud storage instead.
*.pt
*.pth
*.ckpt

# ── Experiment output dirs ────────────────────────────────────────────────────
# Regenerated by running the training scripts.
results/
eval_mid_run/
teste/

# Keep the placeholder so the experiments/ dir structure is preserved
experiments/*
!experiments/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
# Notebooks themselves ARE tracked — they document the research workflow.
# Strip cell outputs before committing:
#   jupyter nbconvert --clear-output --inplace notebooks/*.ipynb

# ── Test / build cache ────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Torch compile cache ───────────────────────────────────────────────────────
__triton_cache__/
torch_compile_debug/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── Credentials (never commit) ────────────────────────────────────────────────
configs/credentials.env

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
